# Server Configuration
PORT=3001

# Gemini API Key (Obtain from Google AI Studio: https://aistudio.google.com)
# If empty, the application will automatically fall back to mock AI responses
# so it remains fully functional and testable immediately out of the box.
GEMINI_API_KEY=your_gemini_api_key_here

# Firebase Configuration (Optional - Simulator is active by default)
FIREBASE_API_KEY=mock_firebase_key
FIREBASE_AUTH_DOMAIN=stadium-ai.firebaseapp.com
FIREBASE_PROJECT_ID=stadium-ai
FIREBASE_STORAGE_BUCKET=stadium-ai.appspot.com
FIREBASE_MESSAGING_SENDER_ID=1234567890
FIREBASE_APP_ID=1:1234567890:web:abcdef123456
